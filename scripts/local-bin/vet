#!/usr/bin/env bash
set -euo pipefail

git rev-parse --is-inside-work-tree >/dev/null 2>&1 || {
  echo "Ошибка: ты не внутри git-репозитория."
  exit 1
}

CURRENT="$(git rev-parse --abbrev-ref HEAD)"

if [ "$CURRENT" != "main" ]; then
  echo "Сейчас ты в ветке: $CURRENT"
  echo "Сначала выполни: main"
  exit 1
fi

read -r -p "Введи название новой ветки: " BRANCH

if [ -z "$BRANCH" ]; then
  echo "Ошибка: название ветки пустое."
  exit 1
fi

git check-ref-format --branch "$BRANCH" >/dev/null 2>&1 || {
  echo "Ошибка: некорректное название ветки: $BRANCH"
  exit 1
}

if git show-ref --verify --quiet "refs/heads/$BRANCH"; then
  echo "Ошибка: такая локальная ветка уже существует: $BRANCH"
  exit 1
fi

git checkout -b "$BRANCH"
