#!/usr/bin/env bash
set -euo pipefail

git rev-parse --is-inside-work-tree >/dev/null 2>&1 || {
  echo "Ошибка: ты не внутри git-репозитория."
  exit 1
}

if [ -n "$(git status --porcelain)" ]; then
  echo "Ошибка: есть незакоммиченные изменения:"
  git status --short
  echo
  echo "Сначала сделай commit, stash или убери изменения."
  exit 1
fi

git fetch origin
git checkout main
git reset --hard origin/main

echo
echo "Готово: локальный main приведён к origin/main."
